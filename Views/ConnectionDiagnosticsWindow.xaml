<Window x:Class="DriveLink.Views.ConnectionDiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Test"
        Height="520" Width="560"
        MinHeight="420" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgDeep}">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,14">
      <TextBlock Text="{Binding Summary}"
                 Foreground="{StaticResource TextPrimary}"
                 FontSize="16" FontWeight="SemiBold"/>
      <TextBlock Text="{Binding DisplayName}"
                 Foreground="{StaticResource TextSecondary}"
                 FontSize="12" Margin="0,4,0,0"/>
    </StackPanel>

    <Border Grid.Row="1"
            Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12,10"
            Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="110"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="HOST"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="0" Grid.Column="1"
                   Text="{Binding Host}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="AUTH"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10" FontWeight="SemiBold"
                   Margin="0,7,0,0"/>
        <TextBlock Grid.Row="1" Grid.Column="1"
                   Text="{Binding AuthMode}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12" Margin="0,7,0,0"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="PATH"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10" FontWeight="SemiBold"
                   Margin="0,7,0,0"/>
        <TextBlock Grid.Row="2" Grid.Column="1"
                   Text="{Binding RemotePath}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12" Margin="0,7,0,0"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="TRUSTED KEY"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10" FontWeight="SemiBold"
                   Margin="0,7,0,0"/>
        <TextBlock Grid.Row="3" Grid.Column="1"
                   Text="{Binding TrustedHostKeyFingerprint, TargetNullValue=(not set)}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12" Margin="0,7,0,0"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="RECEIVED KEY"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10" FontWeight="SemiBold"
                   Margin="0,7,0,0"/>
        <TextBlock Grid.Row="4" Grid.Column="1"
                   Text="{Binding ReceivedHostKeyFingerprint, TargetNullValue=(not received)}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12" Margin="0,7,0,0"
                   TextWrapping="Wrap"/>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Steps}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="78"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Top">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{StaticResource ConnectedGreen}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusText}" Value="Failed">
                          <Setter Property="Foreground" Value="#FF6B6B"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>

                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding Name}"
                             Foreground="{StaticResource TextPrimary}"
                             FontSize="12" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Message}"
                             Foreground="{StaticResource TextSecondary}"
                             FontSize="12" TextWrapping="Wrap"
                             Margin="0,3,0,0"/>
                  <TextBlock Text="{Binding Detail}"
                             Foreground="{StaticResource TextSecondary}"
                             FontSize="11" FontStyle="Italic"
                             TextWrapping="Wrap"
                             Margin="0,5,0,0"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,14,0,0">
      <Button Content="Copy Details"
              Width="110"
              Margin="0,0,8,0"
              Click="Copy_Click"/>
      <Button Content="Close"
              Width="80"
              IsDefault="True"
              Style="{StaticResource PrimaryButton}"
              Click="Close_Click"/>
    </StackPanel>
  </Grid>
</Window>
