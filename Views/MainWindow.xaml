<Window x:Class="DriveLink.Views.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="500" Width="820"
        MinHeight="400" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeep}"
        ResizeMode="CanResize">

  <Window.Title>
    <Binding Path="AppName"/>
  </Window.Title>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="200"/>
    </Grid.ColumnDefinitions>

    <!-- Left: connection list + remote sync indicator -->
    <Border Grid.Column="0" Background="{StaticResource BgDeep}" Padding="16,16,8,16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
        <ListBox Style="{StaticResource ConnectionListBox}"
                 ItemContainerStyle="{StaticResource ConnectionCardItem}"
                 ItemsSource="{Binding Connections}"
                 SelectedItem="{Binding SelectedConnection}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid PreviewMouseRightButtonDown="ConnectionCard_RightClick">
                <Grid.ContextMenu>
                  <ContextMenu>

                    <!-- Edit — disabled for system connections -->
                    <MenuItem Header="Edit…"
                              Command="{Binding DataContext.EditCommand,
                                        Source={x:Reference MainWindowRoot}}"
                              CommandParameter="{Binding}"
                              IsEnabled="{Binding CanEditThis}"/>

                    <!-- Duplicate -->
                    <MenuItem Header="Duplicate"
                              Command="{Binding DataContext.DuplicateCommand,
                                        Source={x:Reference MainWindowRoot}}"
                              CommandParameter="{Binding}"/>

                    <Separator/>

                    <!-- Set Credentials — only for system connections -->
                    <MenuItem Header="Set Credentials…"
                              Command="{Binding DataContext.SetCredentialsCommand,
                                        Source={x:Reference MainWindowRoot}}"
                              CommandParameter="{Binding}"
                              Visibility="{Binding IsSystem, Converter={StaticResource BoolToVisibility}}"/>

                    <Separator Visibility="{Binding IsSystem, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Open in Explorer — only when mounted -->
                    <MenuItem Header="Open in Explorer"
                              Command="{Binding OpenInExplorerCommand}"
                              Visibility="{Binding IsMounted, Converter={StaticResource BoolToVisibility}}"/>

                    <Separator Visibility="{Binding IsMounted, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Delete — red, disabled for system connections -->
                    <MenuItem Header="Delete"
                              Command="{Binding DataContext.DeleteCommand,
                                        Source={x:Reference MainWindowRoot}}"
                              CommandParameter="{Binding}"
                              IsEnabled="{Binding CanDeleteThis}">
                      <MenuItem.Style>
                        <Style TargetType="MenuItem">
                          <Setter Property="Foreground" Value="#FF6B6B"/>
                        </Style>
                      </MenuItem.Style>
                    </MenuItem>

                  </ContextMenu>
                </Grid.ContextMenu>

                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="44"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Drive icon -->
                <Border Grid.Column="0" Width="36" Height="36"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="8" VerticalAlignment="Center">
                  <TextBlock Text="&#xE958;"
                             FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                             FontSize="18"
                             Foreground="{StaticResource TextSecondary}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>
                </Border>

                <!-- Name + meta -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CardTitle}"/>
                    <!-- Lock icon for system connections -->
                    <TextBlock Text="&#xE72E;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="{StaticResource LockColor}"
                               Margin="6,1,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsSystem, Converter={StaticResource BoolToVisibility}}"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <!-- Drive letter badge -->
                    <Border Style="{StaticResource BadgeBorder}" Margin="0,0,6,0">
                      <TextBlock Text="{Binding DriveLetterDisplay}"
                                 Foreground="{StaticResource TextSecondary}"
                                 FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <!-- System badge -->
                    <Border Style="{StaticResource SystemBadgeBorder}" Margin="0,0,6,0"
                            Visibility="{Binding IsSystem, Converter={StaticResource BoolToVisibility}}">
                      <TextBlock Text="SYSTEM"
                                 Foreground="{StaticResource Accent}"
                                 FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="·" Foreground="{StaticResource TextSecondary}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Host}" Style="{StaticResource CardSubtitle}"
                               VerticalAlignment="Center"/>
                    <!-- Live drive letter when mounted -->
                    <TextBlock Text="{Binding MountedDriveText}"
                               Foreground="{StaticResource ConnectedGreen}"
                               FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding IsMounted, Converter={StaticResource BoolToVisibility}}"/>
                  </StackPanel>
                </StackPanel>

                <!-- Status + action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">

                  <!-- Status label — driven by ConnectionViewModel.StatusText -->
                  <TextBlock Text="{Binding StatusText}"
                             VerticalAlignment="Center" Margin="0,0,10,0"
                             FontSize="11" FontWeight="SemiBold" MinWidth="90">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Style.Triggers>
                          <!-- Credentials needed — amber warning -->
                          <DataTrigger Binding="{Binding NeedsCredentials}" Value="True">
                            <Setter Property="Foreground" Value="#FFB340"/>
                          </DataTrigger>
                          <!-- Connection lost — red warning -->
                          <DataTrigger Binding="{Binding IsConnectionLost}" Value="True">
                            <Setter Property="Foreground" Value="#FF6B6B"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsMounted}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource ConnectedGreen}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>

                  <!-- Auto-connect toggle — labelled group -->
                  <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,10,0">
                    <ToggleButton Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding AutoConnect, Mode=TwoWay}"
                                  IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBool}}"
                                  ToolTip="Connect automatically when the app starts"/>
                    <TextBlock Text="Auto Connect"
                               FontSize="8" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                  </StackPanel>

                  <!-- Connecting spinner — visible only while IsConnecting -->
                  <Border Width="20" Height="20"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibility}}">
                    <Ellipse x:Name="Spinner"
                             Width="16" Height="16"
                             Stroke="{StaticResource Accent}"
                             StrokeThickness="2"
                             StrokeDashArray="3 2">
                      <Ellipse.RenderTransform>
                        <RotateTransform CenterX="8" CenterY="8"/>
                      </Ellipse.RenderTransform>
                      <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                          <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                              <DoubleAnimation
                                Storyboard.TargetProperty="RenderTransform.Angle"
                                From="0" To="360" Duration="0:0:1"/>
                            </Storyboard>
                          </BeginStoryboard>
                        </EventTrigger>
                      </Ellipse.Triggers>
                    </Ellipse>
                  </Border>

                  <!-- Folder button — only when mounted -->
                  <Button Style="{StaticResource IconButton}"
                          Visibility="{Binding IsMounted, Converter={StaticResource BoolToVisibility}}"
                          Command="{Binding OpenInExplorerCommand}"
                          ToolTip="Open in Explorer"
                          Margin="0,0,6,0">
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{StaticResource TextSecondary}"/>
                  </Button>

                  <!-- Reconnect — only when the session dropped -->
                  <Button ToolTip="Reconnect this dropped connection"
                          Command="{Binding DataContext.ReconnectCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                          CommandParameter="{Binding}"
                          Visibility="{Binding IsConnectionLost, Converter={StaticResource BoolToVisibility}}"
                          MinWidth="52" Margin="0,0,6,0">
                    <Button.Style>
                      <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                        <Setter Property="Background"  Value="#3A2A1E"/>
                        <Setter Property="BorderBrush" Value="#FFB340"/>
                      </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Width="52">
                      <!-- Circular-arrow refresh icon -->
                      <TextBlock Text="&#xE72C;"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 FontSize="16"
                                 Foreground="#FFB340"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="Reconnect"
                                 HorizontalAlignment="Center"
                                 FontSize="8" FontWeight="SemiBold"
                                 Foreground="#FFB340"
                                 Margin="0,3,0,0"/>
                    </StackPanel>
                  </Button>

                  <!-- Connect / Disconnect toggle -->
                  <Button ToolTip="{Binding ConnectButtonTooltip}"
                          Command="{Binding DataContext.ToggleMountCommand,
                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBool}}"
                          MinWidth="52"
                          Width="Auto"
                          Height="Auto">
                    <Button.Style>
                      <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsMounted}" Value="True">
                            <Setter Property="Background"  Value="#1E4D2E"/>
                            <Setter Property="BorderBrush" Value="{StaticResource ConnectedGreen}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Button.Style>

                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Width="52">
                      <!-- Power icon -->
                      <TextBlock Text="&#xE7E8;"
                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                 FontSize="16"
                                 HorizontalAlignment="Center">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsMounted}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource ConnectedGreen}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsConnectionLost}" Value="True">
                                <Setter Property="Foreground" Value="#FF6B6B"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>

                      <!-- Label: Connect / Disconnect / Connecting… -->
                      <TextBlock HorizontalAlignment="Center"
                                 FontSize="8" FontWeight="SemiBold"
                                 Margin="0,3,0,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text"       Value="Connect"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsMounted}" Value="True">
                                <Setter Property="Text"       Value="Disconnect"/>
                                <Setter Property="Foreground" Value="{StaticResource ConnectedGreen}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsConnectionLost}" Value="True">
                                <Setter Property="Text"       Value="Disconnect"/>
                                <Setter Property="Foreground" Value="#FF6B6B"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                <Setter Property="Text"       Value="Connecting…"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Button>

                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        </ScrollViewer>

        <!-- Remote sync status strip — visible only while background download is running -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,6,0,0"
                    Visibility="{Binding IsRemoteRefreshing,
                                 Converter={StaticResource BoolToVisibility}}">
          <TextBlock Text="&#xE72C;"
                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                     FontSize="11" FontStyle="Italic"
                     Foreground="{StaticResource TextSecondary}"
                     Margin="0,0,5,0"/>
          <TextBlock Text="Syncing remote config…"
                     FontSize="11" FontStyle="Italic"
                     Foreground="{StaticResource TextSecondary}"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- Right: action panel -->
    <Border Grid.Column="1" Background="{StaticResource BgPanel}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1,0,0,0" Padding="12,16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
          <Button Style="{StaticResource ActionButton}" Command="{Binding AddCommand}" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" Style="{StaticResource AccentFluentIcon}"/>
              <TextBlock Text="Add Connection" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource ActionButton}"
                  Command="{Binding ImportCommand}"
                  Visibility="{Binding CanImport, Converter={StaticResource BoolToVisibility}}"
                  Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE896;" Style="{StaticResource AccentFluentIcon}"/>
              <TextBlock Text="Import from SSHFS-Win Manager…" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource ActionButton}"
                  Command="{Binding EditCommand}"
                  CommandParameter="{Binding SelectedConnection}"
                  IsEnabled="{Binding CanEdit}"
                  ToolTip="Edit this connection's server, path, and credentials"
                  Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE70F;" Style="{StaticResource FluentIcon}"/>
              <TextBlock Text="Edit connection" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource ActionButton}"
                  Command="{Binding DuplicateCommand}"
                  CommandParameter="{Binding SelectedConnection}"
                  IsEnabled="{Binding CanDuplicate}"
                  Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8C8;" Style="{StaticResource FluentIcon}"/>
              <TextBlock Text="Duplicate" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Set Credentials — system connections only (user connections edit
               their credentials inline in Edit). Amber dot when credentials are
               still needed, marking it as the obvious next action. -->
          <Button Style="{StaticResource ActionButton}"
                  Command="{Binding SetCredentialsCommand}"
                  IsEnabled="{Binding CanSetCredentials}"
                  Visibility="{Binding ShowSetCredentials, Converter={StaticResource BoolToVisibility}}"
                  ToolTip="Set your username and password for this IT-managed connection"
                  Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8D7;" Style="{StaticResource FluentIcon}"/>
              <TextBlock Text="Set Credentials" VerticalAlignment="Center"/>
              <Ellipse Width="8" Height="8" Fill="#FFB340"
                       VerticalAlignment="Center" Margin="8,0,0,0"
                       ToolTip="Credentials needed before connecting"
                       Visibility="{Binding SelectedNeedsCredentials,
                                    Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
          </Button>

          <Button Style="{StaticResource DangerButton}"
                  Command="{Binding DeleteCommand}"
                  CommandParameter="{Binding SelectedConnection}"
                  IsEnabled="{Binding CanDelete}"
                  Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE74D;" Style="{StaticResource FluentIcon}"/>
              <TextBlock Text="Delete" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <StackPanel Grid.Row="2">
          <Rectangle Height="1" Fill="{StaticResource BorderSubtle}" Margin="0,0,0,8"/>
          <Button Style="{StaticResource ActionButton}" Margin="0,0,0,8" Click="Settings_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE713;" Style="{StaticResource FluentIcon}"/>
              <TextBlock Text="Settings" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="4"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource ActionButton}" Click="About_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE897;" Style="{StaticResource FluentIcon}" Margin="0,0,4,0"/>
                <TextBlock Text="About" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="Exit_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7E8;" Style="{StaticResource FluentIcon}" Margin="0,0,4,0"/>
                <TextBlock Text="Exit" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </Grid>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
