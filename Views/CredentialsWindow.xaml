<Window x:Class="DriveLink.Views.CredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Credentials"
        Height="540" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeep}">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Set Credentials"
                 Foreground="{StaticResource TextPrimary}"
                 FontSize="16" FontWeight="SemiBold"/>
      <TextBlock Text="{Binding DisplayName}"
                 Foreground="{StaticResource TextSecondary}"
                 FontSize="12" Margin="0,4,0,0"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- Read-only server info card -->
        <Border Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1" CornerRadius="6"
                Margin="0,0,0,16" Padding="12,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="HOST"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="10" FontWeight="SemiBold"
                       Width="80" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{Binding HostDisplay}"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="12" Margin="0,0,0,6"/>
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="PATH"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="10" FontWeight="SemiBold"
                       Width="80" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding RemotePath}"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="12"/>
          </Grid>
        </Border>

        <!-- Username -->
        <Label Content="USERNAME"/>
        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12"/>

        <!-- Auth method -->
        <Label Content="AUTHENTICATION"/>
        <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
          <RadioButton Content="Password"    IsChecked="{Binding UsePassword}" Margin="0,0,16,0"/>
          <RadioButton Content="Private Key" IsChecked="{Binding UseKey}"/>
        </StackPanel>
        <TextBlock Text="Use Password if your server requires a login password. Use Private Key for SSH key-pair authentication."
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Label>
          <Label.Style>
            <Style TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
              <Setter Property="Content" Value="PASSWORD STORAGE"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding UseKey}" Value="True">
                  <Setter Property="Content" Value="KEY PASSPHRASE STORAGE"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Label.Style>
        </Label>
        <StackPanel Orientation="Horizontal" Margin="0,2,0,12">
          <RadioButton Content="Remember (encrypted)"
                       IsChecked="{Binding SaveSecret}"
                       Margin="0,0,16,0"/>
          <RadioButton Content="Ask me every time"
                       IsChecked="{Binding AskAtConnect}"/>
        </StackPanel>

        <!-- Password section -->
        <StackPanel Visibility="{Binding UsePassword, Converter={StaticResource BoolToVisibility}}">
          <Label Content="PASSWORD"/>
          <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"/>
        </StackPanel>

        <!-- Private key section -->
        <StackPanel Visibility="{Binding UseKey, Converter={StaticResource BoolToVisibility}}">
          <Label Content="PRIVATE KEY PATH"/>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding PrivateKeyPath}" Margin="0,0,6,0"/>
            <Button  Grid.Column="1" Content="Browse…" Width="68"
                     HorizontalContentAlignment="Center" Click="BrowseKey_Click"/>
          </Grid>
          <Button Content="Generate New Key Pair…"
                  HorizontalAlignment="Left" Width="170" Margin="0,0,0,8"
                  Click="GenerateKey_Click"/>
          <Label Content="KEY PASSPHRASE (OPTIONAL)"/>
          <PasswordBox x:Name="PassphraseBox" Margin="0,0,0,8"/>
        </StackPanel>

        <Label Content="SSH HOST KEY"/>
        <Border Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,8">
          <StackPanel>
            <TextBlock Text="{Binding HostKeyStatus}"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            <TextBlock Text="Paste a verified SHA256 fingerprint, or leave blank to trust the first key received during a successful test or connection."
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,4,0,8"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0"
                       Text="{Binding HostKeyFingerprint, UpdateSourceTrigger=PropertyChanged}"
                       Margin="0,0,6,0"/>
              <Button Grid.Column="1"
                      Content="Reset"
                      Width="68"
                      IsEnabled="{Binding HasHostKeyFingerprint}"
                      Click="ResetHostKey_Click"/>
            </Grid>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <Grid Grid.Row="2" Margin="0,16,0,0">
      <Button Content="Test Connection"
              Width="120"
              HorizontalAlignment="Left"
              Click="TestConnection_Click"/>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button Content="Cancel" Width="80" IsCancel="True" Margin="0,0,8,0"/>
        <Button Content="Save"   Width="80" IsDefault="True"
                Style="{StaticResource PrimaryButton}"
                Click="Save_Click"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
