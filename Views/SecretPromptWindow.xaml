<Window x:Class="DriveLink.Views.SecretPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Credentials Required"
        Height="340" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeep}">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Credentials Required"
                 Foreground="{StaticResource TextPrimary}"
                 FontSize="16" FontWeight="SemiBold"/>
      <TextBlock Text="{Binding DisplayName}"
                 Foreground="{StaticResource TextSecondary}"
                 FontSize="12" Margin="0,4,0,0"/>
    </StackPanel>

    <Border Grid.Row="1"
            Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12,10"
            Margin="0,0,0,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="HOST"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="0" Grid.Column="1"
                   Text="{Binding HostDisplay}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="PATH"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10" FontWeight="SemiBold"
                   Margin="0,7,0,0"/>
        <TextBlock Grid.Row="1" Grid.Column="1"
                   Text="{Binding RemotePath}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12" Margin="0,7,0,0"/>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2">
      <Label Content="{Binding SecretLabel}"/>
      <PasswordBox x:Name="SecretBox" Margin="0,0,0,8"/>
      <TextBlock Text="{Binding HelpText}"
                 Foreground="{StaticResource TextSecondary}"
                 FontSize="11"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,16,0,0">
      <Button Content="Cancel" Width="80" IsCancel="True" Margin="0,0,8,0"/>
      <Button Content="Connect"
              Width="90"
              IsDefault="True"
              Style="{StaticResource PrimaryButton}"
              Click="Connect_Click"/>
    </StackPanel>
  </Grid>
</Window>
