<Window x:Class="DriveLink.Views.ImportConnectionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import from SSHFS-Win Manager"
        Height="460" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeep}">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Import from SSHFS-Win Manager"
               Foreground="{StaticResource TextPrimary}"
               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <TextBlock Grid.Row="1"
               Text="Choose which connections to import. Passwords are not imported — you'll be asked for credentials the first time you connect."
               Foreground="{StaticResource TextSecondary}"
               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>

    <Border Grid.Row="2"
            Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1" CornerRadius="6" Padding="4">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                        Margin="8,6" VerticalContentAlignment="Center">
                <StackPanel Margin="6,0,0,0">
                  <TextBlock Text="{Binding DisplayName}"
                             Foreground="{StaticResource TextPrimary}"
                             FontSize="13" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Detail}"
                             Foreground="{StaticResource TextSecondary}"
                             FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
              </CheckBox>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="3" Margin="0,16,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
        <Button Content="Select All" Width="90" Margin="0,0,8,0" Click="SelectAll_Click"/>
        <Button Content="Deselect All" Width="90" Click="DeselectAll_Click"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Cancel" Width="80" IsCancel="True" Margin="0,0,8,0"/>
        <Button Content="Import Selected" Width="130"
                Style="{StaticResource PrimaryButton}"
                IsDefault="True" Click="Import_Click"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
