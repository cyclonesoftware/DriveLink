<Window x:Class="DriveLink.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DriveLink"
        Title="About"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeep}">

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="About"
               Foreground="{StaticResource TextPrimary}"
               FontSize="16" FontWeight="SemiBold"
               Margin="0,0,0,14"/>

    <!-- About card -->
    <Border Grid.Row="1"
            Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="8">
      <StackPanel>

        <!-- App name -->
        <Grid Height="60" Margin="16,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Image Source="pack://application:,,,/Resources/app-icon-blue.png"
                 Width="40"
                 Height="40"
                 Stretch="Uniform"
                 VerticalAlignment="Center"
                 Margin="0,0,12,0"/>
          <TextBlock Text="{Binding AppName}"
                     Grid.Column="1"
                     Foreground="{StaticResource TextPrimary}"
                     FontSize="15" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
        </Grid>

        <!-- Separator -->
        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="16,0"/>

        <!-- About text -->
        <TextBlock x:Name="AboutTextBlock"
                   Margin="16,12,16,12"
                   TextWrapping="Wrap"
                   LineHeight="20"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="12"/>

        <!-- Separator -->
        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="16,0"/>

        <!-- Version row -->
        <Grid Height="44" Margin="16,0">
          <TextBlock Text="VERSION"
                     Foreground="{StaticResource TextSecondary}"
                     FontSize="11" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding AppVersion}"
                     Foreground="{StaticResource TextPrimary}"
                     FontSize="12"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"/>
        </Grid>

        <!-- Support separator — hidden when no URL is configured -->
        <Border x:Name="SupportSeparator"
                Height="1" Background="{StaticResource BorderSubtle}" Margin="16,0"/>

        <!-- Support URL row — hidden when no URL is configured -->
        <Grid x:Name="SupportRow" Height="44" Margin="16,0">
          <TextBlock Text="SUPPORT"
                     Foreground="{StaticResource TextSecondary}"
                     FontSize="11" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
            <Hyperlink x:Name="SupportLink"
                       Foreground="{StaticResource Accent}"
                       TextDecorations="Underline"
                       RequestNavigate="SupportLink_RequestNavigate">
              <Run x:Name="SupportLinkText"/>
            </Hyperlink>
          </TextBlock>
        </Grid>

        <!-- Separator -->
        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="16,0"/>

        <!-- Support details row -->
        <Grid Height="52" Margin="16,0">
          <TextBlock Text="SUPPORT DETAILS"
                     Foreground="{StaticResource TextSecondary}"
                     FontSize="11" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <Button Command="{Binding CopySupportDetailsCommand}"
                  Width="156"
                  Height="32"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE946;" Style="{StaticResource FluentIcon}"/>
              <TextBlock Text="Copy Details" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>

      </StackPanel>
    </Border>

    <!-- ── Get Involved panel ─────────────────────────────────────
         Shown only when running with default "DriveLink" branding.
         Hidden in code-behind when an organisation has customised AppName.
    ──────────────────────────────────────────────────────────────── -->
    <Border x:Name="DefaultBrandingPanel"
            Grid.Row="2"
            Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="0,12,0,0">
      <StackPanel>

        <!-- Heading -->
        <Grid Height="48" Margin="16,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="❤" FontSize="14"
                       Foreground="{StaticResource Accent}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{x:Static local:Branding.GetInvolvedText}"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Grid>

        <!-- Separator -->
        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="16,0"/>

        <!-- Sponsor row -->
        <StackPanel Margin="16,10,16,10">
          <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="12">
            <Run Text="⭐  "/>
            <Hyperlink x:Name="SponsorLink"
                       Foreground="{StaticResource Accent}"
                       RequestNavigate="SponsorLink_RequestNavigate">
              <Run Text="{x:Static local:Branding.SponsorLabel}"/>
            </Hyperlink>
          </TextBlock>
          <TextBlock Text="{x:Static local:Branding.SponsorDesc}"
                     Foreground="{StaticResource TextSecondary}"
                     FontSize="11" Margin="20,3,0,0"/>
        </StackPanel>

        <!-- Separator -->
        <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="16,0"/>

        <!-- White-label row -->
        <StackPanel Margin="16,10,16,10">
          <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="12">
            <Run Text="🏢  "/>
            <Hyperlink x:Name="WhiteLabelLink"
                       Foreground="{StaticResource Accent}"
                       RequestNavigate="WhiteLabelLink_RequestNavigate">
              <Run Text="{x:Static local:Branding.WhiteLabelLabel}"/>
            </Hyperlink>
          </TextBlock>
          <TextBlock Text="{x:Static local:Branding.WhiteLabelDesc}"
                     Foreground="{StaticResource TextSecondary}"
                     FontSize="11" Margin="20,3,0,0"/>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- Footer -->
    <StackPanel Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="Close" Width="80"
              IsDefault="True" IsCancel="True"
              Style="{StaticResource PrimaryButton}"
              Click="Close_Click"/>
    </StackPanel>
  </Grid>
</Window>
